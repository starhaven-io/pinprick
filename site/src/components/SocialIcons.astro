---
import Default from '@astrojs/starlight/components/SocialIcons.astro';

// Injected at build time from Cargo.toml via Vite `define` in astro.config.mjs.
declare const __PINPRICK_VERSION__: string;
const version = __PINPRICK_VERSION__;
---

{
  version && (
    <a class="version-badge" href={`https://github.com/starhaven-io/pinprick/releases/tag/v${version}`}>
      v{version}
    </a>
  )
}
<Default {...Astro.props} />
